/*
Ingresar 18 valores de temperatura distintos de cero. 
Se pide determinar e informar cuantas ternas (tres valores seguidos) de valores positivos y cuantas de negativos hay.
*/

#include <stdio.h>
#include <stdlib.h>

int main()
{
    int i, countPositivos = 0, countNegativos = 0, ternaPositivo = 0, ternaNegativo = 0;
    float num = 1;
    for (i = 0; i<18; i++){
        printf("Ingrese el valor de la temperatura: ");
        scanf(" %f", &num);
        if (num == 0){
            printf("Los valores de temperatura deben ser distintos de 0\n");
            i--; // se le resta 1 al ciclo for para tener 18 valores de temperatura distintos de 0
        } else {
            if(num > 0){
                countPositivos++; //Si num es positivo suma 1 y resetea el contador de negativos.
                countNegativos = 0;
            } else {
                countNegativos++; //Si num es negativo suma 1 y resetea el contador de positivos.
                countPositivos = 0;
            }
        }
        if (countPositivos == 3){ //si se detecta 3 positivos seguidos se suma 1 a la terna de positivos y resetea el contador de positivos.
            ternaPositivo++;
            countPositivos = 0;
        }
        if (countNegativos == 3){ //si se detecta 3 negativos seguidos se suma 1 a la terna de negativos y resetea el contador de negativos.
            ternaNegativo++;
            countNegativos = 0;
        }
    }
    printf("La cantidad de ternas Positivas es de: %d\n", ternaPositivo);
    printf("La cantidad de ternas Negativas es de: %d\n", ternaNegativo);
    return 0;
}
